{
    "name": "framio/social-share",
    "description": "Forum mesajlarını manuel olarak düzenleyip Meta Business Suite (Facebook/Instagram) üzerinde paylaşır.",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Framio",
            "role": "Developer"
        }
    ],
    "require": {
        "flarum/core": "^2.0"
